PORT=8080

# The URL where your React app will be live on Vercel
FRONTEND_URL=https://your-casano-frontend.vercel.app

# Supabase Credentials (use the Service Role Key for backend administration bypass, or Anon key depending on your RLS logic)
# Get these from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
