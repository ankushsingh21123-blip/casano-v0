PORT=8080

# Frontend & Merchant URLs (for CORS)
FRONTEND_URL=https://casano.in
MERCHANT_URL=https://dukandar.casano.in

# Supabase (Service Role Key = backend only, NEVER expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Secret (use a long random string, min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Firebase Admin SDK (paste the full JSON as one line, or use file path)
FIREBASE_ADMIN_SDK_JSON={"type":"service_account","project_id":"..."}

# Razorpay (sandbox for dev, live for prod)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# UPI VPAs for routing (your platform UPI IDs)
UPI_VPA_GPAY=ankushsingh21123@oksbi
UPI_VPA_PHONEPE=8523048480.upi.circle@ybl
UPI_VPA_PAYTM=8523048480@ptsbi
UPI_VPA_SUPERMONEY=8523048480@superyes

# Optional: Redis for rate limiting / queues
REDIS_URL=redis://localhost:6379

# Optional: Image processing
REMOVEBG_API_KEY=your-removebg-key
